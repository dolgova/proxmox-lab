# ansible/inventory.ini
#
# This file is AUTO-GENERATED by Terraform after `terraform apply`.
# Do not edit manually — your changes will be overwritten.
#
# If you need to run Ansible without running Terraform first,
# you can manually add nodes in this format:
#
# [web_nodes]
# web-node-1 ansible_host=192.168.1.101 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_rsa ansible_ssh_common_args='-o StrictHostKeyChecking=no'
# web-node-2 ansible_host=192.168.1.102 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_rsa ansible_ssh_common_args='-o StrictHostKeyChecking=no'
#
# [web_nodes:vars]
# ansible_python_interpreter=/usr/bin/python3
