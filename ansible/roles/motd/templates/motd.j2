#!/bin/bash
# /etc/update-motd.d/01-proxmox-lab
# Generated by Ansible — do not edit manually
# Template: ansible/roles/motd/templates/motd.j2

cat << 'BANNER'

  ██████╗ ██████╗  ██████╗ ██╗  ██╗███╗   ███╗ ██████╗ ██╗  ██╗
  ██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝████╗ ████║██╔═══██╗╚██╗██╔╝
  ██████╔╝██████╔╝██║   ██║ ╚███╔╝ ██╔████╔██║██║   ██║ ╚███╔╝
  ██╔═══╝ ██╔══██╗██║   ██║ ██╔██╗ ██║╚██╔╝██║██║   ██║ ██╔██╗
  ██║     ██║  ██║╚██████╔╝██╔╝ ██╗██║ ╚═╝ ██║╚██████╔╝██╔╝ ██╗
  ╚═╝     ╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═╝╚═╝     ╚═╝ ╚═════╝ ╚═╝  ╚═╝
                     Private Cloud Lab
BANNER

echo "  ┌─────────────────────────────────────────────────┐"
echo "  │  Node       : {{ ansible_hostname }}"
echo "  │  IP Address : {{ ansible_default_ipv4.address }}"
echo "  │  Cluster    : {{ motd_cluster_name }}"
echo "  │  Role       : {{ motd_node_role }}"
echo "  │  Managed by : Ansible / Terraform"
echo "  │  Proxmox    : {{ motd_proxmox_host }}"
echo "  └─────────────────────────────────────────────────┘"
echo ""

# Show live system state
LOAD=$(cut -d' ' -f1 /proc/loadavg)
MEM_TOTAL=$(grep MemTotal /proc/meminfo | awk '{print $2}')
MEM_AVAIL=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
MEM_USED=$(( (MEM_TOTAL - MEM_AVAIL) * 100 / MEM_TOTAL ))
UPTIME=$(uptime -p | sed 's/up //')
DISK=$(df -h / | awk 'NR==2{print $3"/"$2" ("$5" used)"}')

echo "  System"
echo "  ──────────────────────────────────────────────────"
echo "  Uptime  : $UPTIME"
echo "  Load    : $LOAD"
echo "  Memory  : ${MEM_USED}% used"
echo "  Disk    : $DISK"
echo ""

# Show running services
echo "  Services"
echo "  ──────────────────────────────────────────────────"
for svc in nginx node_exporter; do
  STATUS=$(systemctl is-active $svc 2>/dev/null || echo "not-found")
  if [ "$STATUS" = "active" ]; then
    echo "  ✓  $svc"
  else
    echo "  ✗  $svc ($STATUS)"
  fi
done
echo ""

echo "  ⚠  This system is managed by Ansible. Manual changes will be overwritten."
echo "  ⚠  See /etc/infra-info for provisioning details."
echo ""
