server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html;

    server_name _;

    location / {
        try_files $uri $uri/ =404;
    }

    # Expose node metrics path for dashboard polling
    location /metrics-proxy {
        proxy_pass http://localhost:9100/metrics;
    }
}
